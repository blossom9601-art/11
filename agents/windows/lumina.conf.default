#
# Lumina Agent Configuration
# Blossom IT Asset Management — Asset Discovery Agent
#

[server]
# Server IP or hostname (on first run, the setup wizard will appear)
host =

# Server port (default: 443)
port = 443

# Communication protocol (HTTPS only — HTTP is disabled for security)
protocol = https

# Verify the server TLS/SSL certificate (recommended: true in production)
verify_ssl = true

[agent]
# Collection interval in seconds. Default: 3600 (1 hour)
interval = 3600

# JSON 출력 디렉터리 (서버 전송 실패 시 fallback 저장 경로)
output_dir = C:\ProgramData\Lumina

# 수집 항목 (comma-separated): interface, account, authority, firewalld, storage, package
collectors = interface, account, authority, firewalld, storage, package
