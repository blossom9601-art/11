#
# /etc/blossom/lumina/secure.env
# Blossom Lumina — 비밀값 환경변수 파일
#
# ★★★ 이 파일에는 비밀번호, 토큰, 키가 포함됩니다. ★★★
#   - 소유자: root:root  권한: 0600
#   - 절대로 Git에 커밋하지 마세요
#   - 절대로 로그에 출력하지 마세요
#   - 백업 시 반드시 암호화하세요
#
# systemd EnvironmentFile로 로드됩니다:
#   EnvironmentFile=-/etc/blossom/lumina/secure.env
#
# ★ 설치 후 반드시 모든 CHANGE_ME 값을 실제 비밀값으로 교체하세요!
#

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Flask SECRET_KEY
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 세션 서명, CSRF 토큰 등에 사용되는 비밀 키
# 생성 방법: python3 -c "import secrets; print(secrets.token_hex(32))"
LUMINA_SECRET_KEY=CHANGE_ME_GENERATE_WITH_SECRETS_TOKEN_HEX_32

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DB 계정 — AP Writer
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
LUMINA_DB_AP_USER=lumina_ap_writer
LUMINA_DB_AP_PASSWORD=CHANGE_ME_AP_WRITER_STRONG_PASSWORD

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DB 계정 — WEB Reader
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
LUMINA_DB_WEB_USER=lumina_web_reader
LUMINA_DB_WEB_PASSWORD=CHANGE_ME_WEB_READER_STRONG_PASSWORD

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DB 계정 — Admin (마이그레이션용, localhost에서만 사용)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
LUMINA_DB_ADMIN_USER=lumina_admin
LUMINA_DB_ADMIN_PASSWORD=CHANGE_ME_ADMIN_STRONG_PASSWORD

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Agent 인증 — AP 서버 수신 토큰
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# mTLS를 사용하지 않을 경우, Agent가 Bearer 토큰으로 인증
# 생성 방법: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
LUMINA_AP_AUTH_TOKEN=CHANGE_ME_GENERATE_WITH_SECRETS_TOKEN_URLSAFE_48

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 컬럼 암호화 키 (AES-256)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DB 민감 컬럼 암호화에 사용 (AES_ENCRYPT/AES_DECRYPT)
# 생성 방법: python3 -c "import secrets; print(secrets.token_hex(32))"
LUMINA_COLUMN_ENCRYPT_KEY=CHANGE_ME_GENERATE_WITH_SECRETS_TOKEN_HEX_32

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 백업 암호화 패스프레이즈
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DB 백업 시 openssl enc 또는 gpg 암호화에 사용
LUMINA_BACKUP_PASSPHRASE=CHANGE_ME_BACKUP_STRONG_PASSPHRASE
